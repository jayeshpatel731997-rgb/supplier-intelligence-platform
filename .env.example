NEWSAPI_KEY=your_newsapi_key_here

# Pilot authentication.
SUPPLIER_APP_ADMIN_USER=admin
SUPPLIER_APP_ADMIN_PASSWORD=replace_with_a_strong_password
SUPPLIER_APP_SESSION_TIMEOUT_MINUTES=60
SUPPLIER_APP_DB_PATH=data/pilot_app.db

# Choose one or both LLM providers for Sentinel live news classification.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest
