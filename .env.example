NEWSAPI_KEY=

# Runtime mode. Local/demo permits SQLite fallback. Render staging and
# production should use production security mode, demo mode off, explicit CORS,
# Postgres, OIDC/SAML or an explicit local-auth exception, and object storage.
SUPPLIER_SECURITY_MODE=local
SUPPLIER_DEPLOYMENT_MODE=demo
SUPPLIER_DEMO_MODE=true
AUTH_PROVIDER=local
AUTH_ALLOW_LOCAL_IN_PRODUCTION=false
# Use explicit HTTPS origins before enabling SUPPLIER_SECURITY_MODE=production.
CORS_ALLOW_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SUPPLIER_MAX_UPLOAD_BYTES=5000000
SUPPLIER_ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx,.xls,.json
SUPPLIER_ALLOWED_UPLOAD_MIME_TYPES=text/csv,application/csv,text/plain,application/json,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Upload storage and scanning.
# Local/demo writes tenant-scoped files under SUPPLIER_UPLOAD_STORAGE_PATH.
# Production mode fails readiness unless SUPPLIER_UPLOAD_STORAGE_PROVIDER=s3 and
# the S3-compatible object storage values below are complete.
SUPPLIER_UPLOAD_STORAGE_PROVIDER=local
SUPPLIER_UPLOAD_STORAGE_PATH=data/uploads
SUPPLIER_UPLOAD_STORAGE_BUCKET=
SUPPLIER_UPLOAD_STORAGE_REGION=
SUPPLIER_UPLOAD_STORAGE_ENDPOINT_URL=
SUPPLIER_UPLOAD_STORAGE_ACCESS_KEY_ID=
SUPPLIER_UPLOAD_STORAGE_SECRET_ACCESS_KEY=
SUPPLIER_UPLOAD_STORAGE_KEY_PREFIX=uploads
SUPPLIER_UPLOAD_SCANNER_REQUIRED=false
SUPPLIER_UPLOAD_SCANNER_PROVIDER=none
SUPPLIER_UPLOAD_SCANNER_ENDPOINT_URL=

# Enterprise auth provider placeholders.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256
OIDC_CLOCK_SKEW_SECONDS=60
OIDC_REDIRECT_URI=
SAML_METADATA_URL=
SAML_METADATA_FILE=
SCIM_ENABLED=false
MFA_REQUIRED=false

# Secrets/KMS provider selection. Local/dev values do not require cloud services.
SECRETS_PROVIDER=env
KMS_PROVIDER=local

# Database. Leave as SQLite for local demo; use Render Postgres in staging.
SUPPLIER_DATA_BACKEND=sqlalchemy
SUPPLIER_DATABASE_URL=sqlite:///data/production_app.db
# SUPPLIER_DATABASE_URL=postgresql+psycopg://supplier_app:replace_me@localhost:5432/supplier_intelligence

# FastAPI URL used by Streamlit when deployed separately. Local default is
# http://localhost:8000; staging should point to the API service URL.
SUPPLIER_API_BASE_URL=http://localhost:8000

# Optional Convex foundation status. Leave blank to use SQLAlchemy/local mode.
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Connector mode: stub/demo is deterministic and offline-safe; public uses
# configured public sources and records degraded sync status on failure.
SUPPLIER_CONNECTOR_MODE=demo
SUPPLIER_CONNECTOR_TIMEOUT_SECONDS=10
SUPPLIER_CONNECTOR_RETRY_COUNT=1
SUPPLIER_NEWS_RSS_URLS=
SUPPLIER_NEWS_REQUIRE_SUPPLIER_MATCH=true
SUPPLIER_FILINGS_COMPANY_IDENTIFIER=
SUPPLIER_FILINGS_SOURCE_URLS=
# SEC asks automated clients to identify the application and a monitored contact.
SUPPLIER_FILINGS_USER_AGENT=Supplier Intelligence Platform staging-contact@example.com
SUPPLIER_HIRING_SOURCE_URLS=
SUPPLIER_PUBLIC_CONNECTOR_SUPPLIER_ID=public-supplier
SUPPLIER_PUBLIC_CONNECTOR_SUPPLIER_NAME=Public Source Supplier

# Governed narrative mode. Default remains deterministic/no external calls.
SUPPLIER_LLM_NARRATIVE_PROVIDER=none

# Demo/calibration data paths.
SUPPLIER_DEMO_SCENARIO_PATH=data/demo_supplier_scenarios.json
SUPPLIER_CALIBRATION_OUTCOMES_PATH=data/demo_historical_outcomes.json

# Pilot authentication.
SUPPLIER_APP_ADMIN_USER=admin
SUPPLIER_APP_ADMIN_PASSWORD=
SUPPLIER_APP_SESSION_TIMEOUT_MINUTES=60
SUPPLIER_APP_DB_PATH=data/pilot_app.db
SUPPLIER_APP_MAX_FAILED_ATTEMPTS=5
SUPPLIER_APP_LOCKOUT_MINUTES=15

# Background monitoring.
SUPPLIER_SCHEDULER_ENABLED=true
WORKER_MODE=local
REDIS_URL=redis://redis:6379/0
SUPPLIER_SENTINEL_INTERVAL_MINUTES=60
SUPPLIER_RISK_INTERVAL_MINUTES=120
SUPPLIER_ALERT_EXPOSURE_THRESHOLD=100000

# Retention and SIEM export readiness.
RETENTION_ENABLED=false
RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=2555
BACKUP_RETENTION_DAYS=35
SIEM_SINK=file
SIEM_WEBHOOK_URL=

# Multi-tenant API demo defaults.
# Local/demo mode seeds tenant `demo-tenant` with API key `demo-api-key`.
# OIDC staging seeds a local membership for this subject/email without creating
# an API key. SUPPLIER_DEMO_API_KEY is only for local/demo or an approved
# time-bounded local-auth staging exception.
DEFAULT_TENANT_ID=demo-tenant
SUPPLIER_DEMO_API_KEY=
SUPPLIER_STAGING_SEED_USERNAME=
DEFAULT_PLATFORM_ADMIN=demo-platform-admin

# WorkOS placeholders for later SSO/SCIM integration.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=

# Choose one or both LLM providers for Sentinel live news classification.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Staging smoke test inputs. Do not commit real values.
# STAGING_API_BASE_URL is preferred; STAGING_BASE_URL remains a compatible alias.
STAGING_API_BASE_URL=
STAGING_BASE_URL=
STAGING_UI_BASE_URL=
STAGING_EXPECTED_TENANT_ID=
STAGING_TENANT_ID=
STAGING_API_KEY=
STAGING_BEARER_TOKEN=
