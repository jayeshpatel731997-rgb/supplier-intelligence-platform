NEWSAPI_KEY=your_newsapi_key_here

# Runtime mode.
# demo/local permits SQLite fallback and optional demo intelligence.
# production disables unsafe default admin creation.
SUPPLIER_SECURITY_MODE=local
SUPPLIER_DEPLOYMENT_MODE=demo
SUPPLIER_DEMO_MODE=true
AUTH_PROVIDER=local
AUTH_ALLOW_LOCAL_IN_PRODUCTION=false
CORS_ALLOW_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Enterprise auth provider placeholders.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_REDIRECT_URI=
SAML_METADATA_URL=
SAML_METADATA_FILE=
SCIM_ENABLED=false
MFA_REQUIRED=false

# Secrets/KMS provider selection. Local/dev values do not require cloud services.
SECRETS_PROVIDER=env
KMS_PROVIDER=local

# Production database. Leave as SQLite for local demo; use Postgres in production-like deployments.
SUPPLIER_DATABASE_URL=sqlite:///data/production_app.db
# SUPPLIER_DATABASE_URL=postgresql+psycopg://supplier_app:replace_me@localhost:5432/supplier_intelligence

# Pilot authentication.
SUPPLIER_APP_ADMIN_USER=admin
SUPPLIER_APP_ADMIN_PASSWORD=replace_with_a_strong_password
SUPPLIER_APP_SESSION_TIMEOUT_MINUTES=60
SUPPLIER_APP_DB_PATH=data/pilot_app.db
SUPPLIER_APP_MAX_FAILED_ATTEMPTS=5
SUPPLIER_APP_LOCKOUT_MINUTES=15

# Background monitoring.
SUPPLIER_SCHEDULER_ENABLED=true
WORKER_MODE=local
REDIS_URL=redis://redis:6379/0
SUPPLIER_SENTINEL_INTERVAL_MINUTES=60
SUPPLIER_RISK_INTERVAL_MINUTES=120
SUPPLIER_ALERT_EXPOSURE_THRESHOLD=100000

# Retention and SIEM export readiness.
RETENTION_ENABLED=false
RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=2555
BACKUP_RETENTION_DAYS=35
SIEM_SINK=file
SIEM_WEBHOOK_URL=

# Multi-tenant API demo defaults.
# Local/demo mode seeds tenant `demo-tenant` with API key `demo-api-key`.
# Production deployments should rotate/create tenant keys through the admin API.
DEFAULT_TENANT_ID=demo-tenant
SUPPLIER_DEMO_API_KEY=replace_with_long_random_staging_key
DEFAULT_PLATFORM_ADMIN=demo-platform-admin

# WorkOS placeholders for later SSO/SCIM integration.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=

# Choose one or both LLM providers for Sentinel live news classification.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest
